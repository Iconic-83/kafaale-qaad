# ────────────────────────────────────────────────────────────────
# Kafaale Qaad API — Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────────
# Local:
DATABASE_URL="postgresql://postgres:password@localhost:5432/kafaale_qaad"
# Railway example:
# DATABASE_URL="postgresql://user:pass@host.railway.app:5432/railway"

# ── Authentication ───────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ── AI Sanitization (Anthropic Claude) ──────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── File Uploads ─────────────────────────────────────────────────
BASE_URL="http://localhost:4000"
# For production (Railway/Render):
# BASE_URL="https://your-api.railway.app"

# ── Frontend URL (CORS) ──────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
# For production:
# FRONTEND_URL="https://your-frontend.vercel.app"
