# ────────────────────────────────────────────────────────────────
# Kafaale Qaad API — Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (Supabase PostgreSQL) ───────────────────────────────
# Get both URLs from: Supabase Dashboard → Project Settings → Database → Connection String
#
# 1. DATABASE_URL  = "Transaction" pooler URL (port 6543) — used by the running app
# 2. DIRECT_URL    = "Session" / direct URL  (port 5432) — used by prisma migrate only
#
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Authentication ───────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ── AI Sanitization (Anthropic Claude) ──────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── File Uploads ─────────────────────────────────────────────────
BASE_URL="http://localhost:4000"
# For production:
# BASE_URL="https://your-api.railway.app"

# ── Frontend URL (CORS) ──────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
# For production:
# FRONTEND_URL="https://your-frontend.vercel.app"

# ── Supabase (optional — for Storage / Auth later) ───────────────
# SUPABASE_URL="https://[project-ref].supabase.co"
# SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."
