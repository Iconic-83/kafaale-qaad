generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  phone             String?
  password          String
  role              String    @default("reporter")
  preferredLanguage String    @default("en")
  country           String?
  city              String?
  organization      String?
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  reportedCases       Case[]              @relation("CaseReporter")
  assignedCases       Case[]              @relation("CaseAssignedAgent")
  fieldInvestigations FieldInvestigation[]
  donations           Donation[]
  auditLogs           AdminAuditLog[]
  notifications       Notification[]
}

model Case {
  id              String    @id @default(cuid())
  reporterId      String?
  reporter        User?     @relation("CaseReporter", fields: [reporterId], references: [id])
  assignedAgentId String?
  assignedAgent   User?     @relation("CaseAssignedAgent", fields: [assignedAgentId], references: [id])

  privateVictimName   String?
  privateVictimPhone  String?
  privateAddress      String?
  privateGpsLat       Float?
  privateGpsLng       Float?
  privateFamilySize   Int?
  privateVictimAge    Int?
  privateVictimGender String?
  privateDescription  String
  privateNotes        String?

  category        String   @default("other")
  emergencyLevel  String   @default("medium")
  supportType     String?
  status          String   @default("pending_review")
  rejectedAt      DateTime?
  rejectionReason String?

  targetGoal      Float    @default(0)
  totalRaised     Float    @default(0)
  escrowReleased  Float    @default(0)

  publicTitle      String?
  publicStory      String?
  publicCity       String?
  publicCountry    String?
  publicMediaUrls  String?
  aiSanitizedAt    DateTime?
  adminPublishedAt DateTime?

  teamAssignedAt           DateTime?
  investigationCompletedAt DateTime?
  sponsoredAt              DateTime?
  completedAt              DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  mediaFiles         CaseMedia[]
  fieldInvestigation FieldInvestigation?
  aiPublicData       AiPublicData?
  deliveryProof      DeliveryProof?
  donations          Donation[]
  auditLogs          AdminAuditLog[]
  notifications      Notification[]
}

model CaseMedia {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id])
  type       String   @default("image")
  url        String
  filename   String
  mimeType   String
  sizeBytes  Int?
  isPublic   Boolean  @default(false)
  isFlagged  Boolean  @default(false)
  flagReason String?
  uploadedBy String?
  uploadedAt DateTime @default(now())
}

model FieldInvestigation {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])
  agentId String
  agent   User   @relation(fields: [agentId], references: [id])

  victimVerified        Boolean @default(false)
  situationAccurate     Boolean @default(false)
  situationNotes        String?
  gpsVerificationLat    Float?
  gpsVerificationLng    Float?
  estimatedAmountNeeded Float   @default(0)
  urgencyConfirmed      String?
  deliveryFeasible      Boolean @default(true)
  deliveryMethod        String?
  deliveryNotes         String?
  fraudRiskScore        Int     @default(0)
  fraudRiskLevel        String  @default("low")
  fraudRiskNotes        String?
  verificationStatus    String  @default("needs_review")
  officialNotes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiPublicData {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  generatedTitle    String
  generatedStory    String
  generatedCategory String
  generatedCity     String?
  generatedUrgency  String
  safeMediaUrls     String?
  piiDetected       Boolean @default(false)
  piiRemoved        String?
  mediaFlagged      String?
  confidenceScore   Int     @default(0)
  adminEdited       Boolean @default(false)
  adminEditedTitle  String?
  adminEditedStory  String?
  model             String  @default("claude-sonnet-4-6")
  tokensUsed        Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Donation {
  id             String    @id @default(cuid())
  donorId        String
  donor          User      @relation(fields: [donorId], references: [id])
  caseId         String
  case           Case      @relation(fields: [caseId], references: [id])
  amount         Float
  currency       String    @default("USD")
  method         String    @default("bank_transfer")
  status         String    @default("pending")
  transactionRef String?
  confirmedAt    DateTime?
  isAnonymous    Boolean   @default(false)
  donorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DeliveryProof {
  id              String    @id @default(cuid())
  caseId          String    @unique
  case            Case      @relation(fields: [caseId], references: [id])
  deliveredBy     String
  deliveryDate    DateTime
  deliveryMethod  String
  amountDelivered Float
  recipientName   String?
  deliveryNotes   String?
  photoUrls       String?
  adminConfirmed  Boolean   @default(false)
  adminConfirmedAt DateTime?
  adminNotes      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id])
  action    String
  notes     String?
  metadata  String?
  ipAddress String?
  timestamp DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  caseId    String?
  case      Case?     @relation(fields: [caseId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model IdempotencyKey {
  key       String   @id
  createdAt DateTime @default(now())
}
